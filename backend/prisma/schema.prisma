generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  favorites    Favorite[]
  notes        Note[]
  progress     Progress[]
  history ReadingHistory[]
}

model QuranSurah {
  id          Int         @id
  name        String
  englishName String
  ayahs       QuranAyah[]
}

model QuranAyah {
  id       String     @id @default(cuid())
  surahId  Int
  number   Int
  text     String
  juz      Int
  notes    Note[]
  progress Progress[]
  history ReadingHistory[]
  surah    QuranSurah @relation(fields: [surahId], references: [id])
  @@index([surahId, number])
  @@index([juz])
}

model Progress {
  id        String    @id @default(cuid())
  userId    String
  updatedAt DateTime  @updatedAt
  ayahId    String

  user User      @relation(fields: [userId], references: [id])
  ayah QuranAyah @relation(fields: [ayahId], references: [id])

  @@unique([userId])
}

model ReadingHistory {
  id String @id @default(cuid())

  userId String
  ayahId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  ayah QuranAyah @relation(fields: [ayahId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Favorite {
  id        String       @id @default(cuid())
  userId    String
  type      FavoriteType
  refId     String
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
  @@unique([userId, type, refId])
}

model Note {
  id        String     @id @default(cuid())
  userId    String
  ayahId    String?
  content   String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  ayah QuranAyah? @relation(fields: [ayahId], references: [id])
  user User       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, ayahId])
}

model HadithBook {
  id          String @id @default(cuid())

  sourceId    Int    @unique

  slug        String @unique
  name        String
  description String?

  hadiths Hadith[]
}

model Hadith {
  id String @id @default(cuid())

  sourceId Int @unique

  bookId String

  hadithNumber Int?

  chapterId Int?

  chapter String?

  narrator String?

  arabicText String?

  englishText String

  book HadithBook @relation(fields: [bookId], references: [id])

  @@index([bookId])
  @@index([hadithNumber])
}

model DuaCategory {
  id String @id @default(cuid())

  sourceId Int @unique

  slug String @unique

  name String

  duas Dua[]
}

model Dua {
  id String @id @default(cuid())

  sourceId Int @unique

  categoryId String

  title String

  arabicText String

  transliteration String?

  englishText String

  repeat Int?

  audioUrl String?

  category DuaCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

model Topic {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  topicMaps TopicMap[]
}

model TopicMap {
  id      String          @id @default(cuid())
  topicId String
  type    TopicTargetType
  refId   String
  topic   Topic           @relation(fields: [topicId], references: [id])

  @@index([type, refId])
}

enum FavoriteType {
  QURAN
  HADITH
  DUA
}

enum TopicTargetType {
  QURAN
  HADITH
  DUA
}
